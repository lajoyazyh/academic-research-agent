# LLM provider configuration
# For public demos, leave API keys unset and let visitors use the in-app BYOK panel.
# These variables are only a private/local server fallback.
ZHIPU_API_KEY=your_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4-flash

# Optional OpenAI-compatible key fallback
# OPENAI_API_KEY=your_openai_compatible_key

# Agent behavior
AGENT_MIN_PAPERS=3
AGENT_LOOP_DELAY_SEC=3
ARXIV_SEARCH_RETRY_LIMIT=3

# Optional external academic API keys
# SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key
# ARXIV_USER_AGENT=AcademicResearchAgent/1.0 (mailto:you@example.com)
# SCHOLAR_CONTACT_EMAIL=you@example.com

# Deployment
PORT=8000

# Public multi-user deployment (backend only)
# When SUPABASE_URL and SUPABASE_ANON_KEY are set, all /api routes require login.
# Never expose SUPABASE_SERVICE_ROLE_KEY to the browser or Vercel frontend.
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_public_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_backend_only_service_role_key
# SUPABASE_STORAGE_BUCKET=research-workspaces
# CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Vercel frontend build variables (set in Vercel Project Settings)
# PUBLIC_API_BASE_URL=https://your-backend.onrender.com
# PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# PUBLIC_SUPABASE_ANON_KEY=your_public_anon_key

# GitHub OAuth is configured in Supabase Authentication > Providers > GitHub.
# The browser requests: repo read:user user:email. GitHub provider tokens are
# kept in sessionStorage and sent only with explicit repository/export calls.
# Supabase callback: https://<project-ref>.supabase.co/auth/v1/callback
