{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "rewrites": [
    { "source": "/app/console", "destination": "/console" },
    { "source": "/app/history", "destination": "/history" },
    { "source": "/app/chat", "destination": "/chat" },
    { "source": "/app/help", "destination": "/help" },
    { "source": "/app/skills", "destination": "/skills" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
